{
  "name": "@podmind/types",
  "version": "0.0.0",
  "private": true,
  "description": "Database-generated and shared domain types",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./database": {
      "types": "./dist/database.d.ts",
      "require": "./dist/database.js",
      "default": "./dist/database.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate": "node scripts/generate-db-types.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@podmind/config": "workspace:*",
    "pg": "^8.13.1",
    "typescript": "^5.7.2"
  }
}
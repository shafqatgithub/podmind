    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@podmind/config": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }

# ============================================================================
# PodMind AI — API environment template
# Copy to .env for local development. In production these are Railway
# environment variables. NEVER commit a real .env.
# ============================================================================

# --- Runtime ----------------------------------------------------------------
ENV=development                       # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# --- Supabase ----------------------------------------------------------------
# Project settings -> API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # server-side only, never in web

# --- Database ----------------------------------------------------------------
# Project settings -> Database -> Connection string (Session pooler, port 5432)
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# --- Secrets -------------------------------------------------------------------
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<fernet-key>

# --- Platform AI provider keys (optional per provider; users may BYOK) --------
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# PodMind API — environment (Railway par yehi variables set honge)
NODE_ENV=development
PORT=8000
CORS_ORIGINS=http://localhost:3000,https://podmind-web.vercel.app

# Supabase Postgres (Session pooler). DB_SSL=true for Supabase.
DATABASE_URL=postgres://postgres:localtest@localhost:5432/docs_schema_test
DB_SSL=false

# Supabase (Stage 6 - Authentication - me required ho jayenge)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Build context for the API image.
#
# Without this file the context was 1.5 GB — node_modules at 782 MB and the
# web app's .next output at 599 MB, neither of which the API container has any
# use for. The Nixpacks plan copies the context three times, so every byte was
# paid for three times over, and the image grew with each module added.
#
# Deliberately conservative: every package.json stays, because pnpm's
# workspace install reads all of them and fails if one is missing. Only
# regenerable output and things the container never reads are excluded.

# Installed inside the image, never copied into it.
node_modules
**/node_modules
.pnpm-store

# Regenerated by the build.
.next
**/.next
dist
**/dist
.turbo
**/.turbo
*.tsbuildinfo

# The web app's own assets and source are built and served by Vercel; its
# package.json stays so the workspace install still resolves.
apps/web/.next
apps/web/public
apps/web/src

# History, tooling, editor state.
.git
.github
.vscode
.idea
*.log

# Tests run in CI, not in the container.
**/*.spec.ts
**/*.test.ts
apps/api/test
supabase/tests

# Applied out of band, not by the container.
docs
supabase/deploy

# Reference implementation kept for history; nothing imports it.
legacy

# Local environment files must never reach an image.
.env
.env.local
.env.*.local
